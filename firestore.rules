rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /reservations/{reservationId} {
      // Public read — needed for the availability check on the booking form
      allow read: if true;

      // Only allow create when all required fields are present
      allow create: if request.resource.data.keys().hasAll([
                        'carName', 'firstName', 'lastName', 'phone',
                        'passportNumber', 'startDate', 'endDate'
                      ])
                    && request.resource.data.carName is string
                    && request.resource.data.firstName is string
                    && request.resource.data.lastName is string
                    && request.resource.data.phone is string
                    && request.resource.data.passportNumber is string
                    && request.resource.data.startDate is timestamp
                    && request.resource.data.endDate is timestamp;

      // Never allow update or delete from the client
      allow update, delete: if false;
    }
  }
}
